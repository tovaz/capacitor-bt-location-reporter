{
  "name": "capacitor-bt-location-reporter",
  "version": "0.1.0",
  "description": "Capacitor plugin for background BLE auto-connect and GPS location reporting",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "BtLocationReporter.podspec"
  ],
  "author": "PAJ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/capacitor-bt-location-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_ORG/capacitor-bt-location-reporter/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "bluetooth",
    "ble",
    "gps",
    "background",
    "location"
  ],
  "scripts": {
    "build": "npm run clean && tsc && rollup -c rollup.config.js",
    "clean": "rimraf ./dist",
    "lint": "eslint . --ext ts",
    "fmt": "prettier --write --parser typescript \"src/**/*.ts\""
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^7.0.0"
  },
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
